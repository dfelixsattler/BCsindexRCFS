Package: SIndexRCFS
Type: Package
Title: Site Index Tools in R for PSP and Growth Workflows
Version: 0.2.0
Date: 2026-06-17
Authors@R: c(
  person("Derek Felix", "Sattler", email = "derekfelixsattler@gmail.com", role = c("aut", "cre")),
  person("Yong", "Luo", role = "ctb", comment = "Original SIndexR package author"),
  person("Ken", "Polsson", role = "ctb", comment = "Original Sindex C implementation")
