% Generated by hand for the validation helper
\name{ValidateSiteTools}
\alias{ValidateSiteTools}
\title{Validate SiteTools CSV exports against SIndexR}
\usage{
ValidateSiteTools(
  fd_csv,
  cw_csv,
  output_dir = dirname(fd_csv),
  use_external_dll = FALSE,
  external_dll_path = NULL,
  save_results = TRUE,
  verbose = TRUE
)
}
\arguments{
\item{fd_csv}{path to the Douglas-fir SiteTools CSV export}

\item{cw_csv}{path to the western redcedar SiteTools CSV export}

\item{output_dir}{directory where comparison CSV files are written}

\item{use_external_dll}{logical; if TRUE, enable runtime external DLL mode for the run}

\item{external_dll_path}{optional DLL path to load before validating}

\item{save_results}{logical; write comparison CSVs to \code{output_dir}}

\item{verbose}{logical; print summaries to the console}
}
\value{
a list with \code{fd}, \code{cw}, and \code{files} entries
}
\description{
Reads SiteTools CSV exports, compares the height table against the corresponding SIndexR wrapper, and optionally writes comparison CSV files.

Set \code{use_external_dll = TRUE} to route supported wrappers through the runtime DLL backend configured via \code{SIndexR_SetExternalDll()}.
}
\examples{
\dontrun{
ValidateSiteTools(
  fd_csv = "C:/SIndexR/my_tests/SiteToolsExport_Fd.csv",
  cw_csv = "C:/SIndexR/my_tests/SiteToolsExport_Cw.csv",
  output_dir = "C:/SIndexR/my_tests",
  use_external_dll = TRUE,
  external_dll_path = "C:/sindex64.dll"
)
}
}
